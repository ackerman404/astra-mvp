# Astra Backend Configuration
# Copy this file to .env and fill in your values

# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Database URL (defaults to SQLite)
# DATABASE_URL=sqlite:///./astra_backend.db

# Optional: Allowed models (comma-separated)
# ALLOWED_MODELS=gpt-4o,gpt-4o-mini

# Optional: Rate limits (requests per minute)
# RATE_LIMIT_COMPLETIONS_RPM=20
# RATE_LIMIT_CLASSIFICATIONS_RPM=60

# Optional: OpenAI request timeouts (seconds)
# OPENAI_TIMEOUT_GENERATE=60.0
# OPENAI_TIMEOUT_CLASSIFY=30.0
